MONGO_URI=mongodb://localhost:27017/mttms
ADMIN_NAME=System Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin@123
NODE_ENV=development

# Authentication
ACCESS_TOKEN_SECRET=your_access_token_secret
ACCESS_TOKEN_EXPIRE=15m
REFRESH_TOKEN_SECRET=your_refresh_token_secret
REFRESH_TOKEN_EXPIRE=7d

# Email (Gmail SMTP) — see backend/EMAIL_SETUP.md
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your.email@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_FROM="BONTECH <your.email@gmail.com>"
APP_NAME=BONTECH
FRONTEND_URL=http://localhost:5173
# Optional: recipient for npm run test:email (defaults to SMTP_USER)
# TEST_EMAIL=recipient@example.com

